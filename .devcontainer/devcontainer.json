{
    "name": "Ruby",
    "image": "mcr.microsoft.com/devcontainers/jekyll",

    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                "streetsidesoftware.code-spell-checker",
                "mathematic.vscode-pdf",
                "DavidAnson.vscode-markdown",
                "ms-python.python"
            ]
        }
    },

    "portsAttributes": {
        "4000": {
            "label": "Application",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "bundle install"
}